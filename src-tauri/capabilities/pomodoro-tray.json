{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "pomodoro-tray",
  "description": "Permissions for the macOS Pomodoro tray popover window.",
  "windows": ["pomodoro-tray"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:allow-hide",
    "core:window:allow-set-shadow",
    "core:window:allow-set-background-color",
    "core:window:allow-set-effects",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-exists",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-appdata-read-recursive",
    {
      "identifier": "fs:scope",
      "allow": ["$APPCONFIG", "$APPCONFIG/**", "$APPDATA", "$APPDATA/**"]
    },
    "positioner:default"
  ]
}
