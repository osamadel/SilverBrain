{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SilverBrain",
  "version": "0.2.2",
  "identifier": "com.silverbrain.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "SilverBrain",
        "width": 1100,
        "height": 760,
        "minWidth": 880,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false,
        "backgroundThrottling": "disabled"
      },
      {
        "label": "pomodoro-tray",
        "title": "Focus Timer",
        "url": "tray-popover.html",
        "width": 284,
        "height": 172,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true
      },
      {
        "label": "quick-add",
        "title": "Quick Add",
        "url": "quick-add.html",
        "width": 688,
        "height": 300,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "visible": false,
        "resizable": false,
        "skipTaskbar": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
